#!/bin/sh
set -eu

changed_files="$(git diff --cached --name-only)"

if [ -z "$changed_files" ]; then
  exit 0
fi

if ! echo "$changed_files" | grep -Eq '^(app\.py|launcher\.py|build\.bat|requirements\.txt|set-version\.ps1|frontend/(next\.config\.ts|package\.json|package-lock\.json|components/|lib/|pages/|scripts/|styles/))'; then
  exit 0
fi

if ! echo "$changed_files" | grep -qx "VERSION"; then
  cat >&2 <<'EOF'
Version bump required.

Product, UI, bugfix, or build files are staged, but VERSION is not staged.
Run:
  powershell -ExecutionPolicy Bypass -File .\set-version.ps1 <major.minor.patch>
Then stage VERSION and the package metadata with your change.
EOF
  exit 1
fi
